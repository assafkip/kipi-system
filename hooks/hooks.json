{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_DATA}/.venv\" || (cd \"${CLAUDE_PLUGIN_ROOT}/kipi-mcp\" && uv sync --quiet)"
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/q-system/hooks/session-start.py\""
          }
        ]
      }
    ]
  }
}
