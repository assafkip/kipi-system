!**/.gitkeep

# Plans (auto-created by Claude Code)
.claude/plans/

# Session transcripts
*.jsonl

# SQLite databases (generated at runtime)
*.db

# Generated sites and build output
sites/
template-repo/

# Bus data (daily pipeline, ephemeral)
q-system/.q-system/agent-pipeline/bus/

# Node
node_modules/
